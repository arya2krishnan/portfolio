# Apple Music API (MusicKit)
# Create a MusicKit key at https://developer.apple.com/account/resources/authkeys
APPLE_MUSIC_KEY_ID=your_key_id_here
APPLE_MUSIC_TEAM_ID=your_team_id_here
APPLE_MUSIC_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour_key_content_here\n-----END PRIVATE KEY-----"

# Vercel Blob Storage for media files (photos, MP3s, etc.)
# Created automatically when you add Blob storage in Vercel dashboard
BLOB_READ_WRITE_TOKEN=your_blob_token_here
